<UserControl
    x:Class="DevCenter.Views.CommandFormView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:DevCenter.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="750"
    d:DesignWidth="1200"
    mc:Ignorable="d">

    <UserControl.Resources>

        <Style x:Key="SectionHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Margin" Value="0,0,0,2" />
        </Style>

        <Style x:Key="SectionSubStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11.5" />
            <Setter Property="Foreground" Value="#666" />
            <Setter Property="Margin" Value="0,0,0,16" />
        </Style>

        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Foreground" Value="#888888" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,0,6" />
        </Style>

        <Style x:Key="HintStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Foreground" Value="#555" />
            <Setter Property="Margin" Value="0,5,0,0" />
        </Style>

        <Style x:Key="InputStyle" TargetType="TextBox">
            <Setter Property="Background" Value="#1A1A1E" />
            <Setter Property="Foreground" Value="#E0E0E0" />
            <Setter Property="BorderBrush" Value="#2E2E34" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="10,9" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="CaretBrush" Value="#E0E0E0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border
                            x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#2563EB" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#3a3a40" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style
            x:Key="CodeInputStyle"
            BasedOn="{StaticResource InputStyle}"
            TargetType="TextBox">
            <Setter Property="FontFamily" Value="Consolas" />
            <Setter Property="FontSize" Value="12.5" />
            <Setter Property="Foreground" Value="#7DD3FC" />
            <Setter Property="AcceptsReturn" Value="True" />
            <Setter Property="AcceptsTab" Value="True" />
            <Setter Property="VerticalScrollBarVisibility" Value="Auto" />
            <Setter Property="Padding" Value="14" />
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#2563EB" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="18,8" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            Padding="{TemplateBinding Padding}"
                            Background="{TemplateBinding Background}"
                            CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1D4ED8" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#1E40AF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CancelButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#888888" />
            <Setter Property="BorderBrush" Value="#2E2E34" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="16,8" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            Padding="{TemplateBinding Padding}"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="#AAAAAA" />
                                <Setter Property="BorderBrush" Value="#444444" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ScrollBarThumbStyle" TargetType="Thumb">
            <Setter Property="Background" Value="#2a2a2a" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border Background="{TemplateBinding Background}" CornerRadius="3" />
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#3a3a3a" />
                            </Trigger>
                            <Trigger Property="IsDragging" Value="True">
                                <Setter Property="Background" Value="#4a4a4a" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ScrollBarStyle" TargetType="ScrollBar">
            <Setter Property="Width" Value="6" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="Transparent">
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageUpCommand" Opacity="0" />
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Margin="1,0" Style="{StaticResource ScrollBarThumbStyle}" />
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageDownCommand" Opacity="0" />
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ScrollViewer">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollViewer">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <ScrollContentPresenter Grid.Row="0" Grid.Column="0" />
                            <ScrollBar
                                x:Name="PART_VerticalScrollBar"
                                Grid.Row="0"
                                Grid.Column="1"
                                Maximum="{TemplateBinding ScrollableHeight}"
                                Style="{StaticResource ScrollBarStyle}"
                                ViewportSize="{TemplateBinding ViewportHeight}"
                                Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}"
                                Value="{TemplateBinding VerticalOffset}" />
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </UserControl.Resources>

    <Grid Background="#111111">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!--  Form body  -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel
                MaxWidth="720"
                Margin="24,20,24,24"
                HorizontalAlignment="Stretch">

                <!--  Section: Basics  -->
                <TextBlock Style="{StaticResource SectionHeaderStyle}" Text="Basics" />
                <TextBlock Style="{StaticResource SectionSubStyle}" Text="What this command does and when to run it." />

                <!--  Name  -->
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Style="{StaticResource LabelStyle}" Text="NAME" />
                        <TextBlock
                            Margin="2,0,0,6"
                            FontSize="11"
                            Foreground="#e24b4a"
                            Text="*" />
                    </StackPanel>
                    <TextBox
                        Style="{StaticResource InputStyle}"
                        Tag="e.g. Clean Build Cache"
                        Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>

                <!--  Description  -->
                <StackPanel Margin="0,16,0,0">
                    <TextBlock Style="{StaticResource LabelStyle}" Text="DESCRIPTION" />
                    <TextBox
                        Style="{StaticResource InputStyle}"
                        Tag="What does this command do and when would you run it?"
                        Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}" />
                    <TextBlock Style="{StaticResource HintStyle}" Text="One sentence is enough — this shows in the command list." />
                </StackPanel>

                <!--  Divider  -->
                <Border
                    Height="1"
                    Margin="0,24,0,24"
                    Background="#1e1e22" />

                <!--  Section: Classification  -->
                <TextBlock Style="{StaticResource SectionHeaderStyle}" Text="Classification" />
                <TextBlock Style="{StaticResource SectionSubStyle}" Text="Helps you find this command later." />

                <!--  Tags  -->
                <StackPanel>
                    <TextBlock Style="{StaticResource LabelStyle}" Text="TAGS" />
                    <TextBox
                        Style="{StaticResource InputStyle}"
                        Tag="windows, cleanup, build"
                        Text="{Binding Tags, UpdateSourceTrigger=PropertyChanged}" />
                    <TextBlock Style="{StaticResource HintStyle}" Text="Comma-separated keywords — used by search." />
                </StackPanel>

                <!--  Divider  -->
                <Border
                    Height="1"
                    Margin="0,24,0,24"
                    Background="#1e1e22" />

                <!--  Section: Script  -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Style="{StaticResource SectionHeaderStyle}" Text="Script" />
                        <TextBlock Style="{StaticResource SectionSubStyle}" Text="Paste the command exactly as you'd want to run it." />
                    </StackPanel>
                    <TextBlock
                        Grid.Column="1"
                        Margin="0,1,0,0"
                        VerticalAlignment="Top"
                        FontSize="11"
                        Foreground="#444"
                        Text="{Binding Script.Length, StringFormat='{}{0} chars'}" />
                </Grid>

                <TextBox
                    Height="160"
                    Margin="0,12,0,0"
                    Style="{StaticResource CodeInputStyle}"
                    Text="{Binding Script, UpdateSourceTrigger=PropertyChanged}" />

            </StackPanel>
        </ScrollViewer>

        <!--  Footer  -->
        <Border
            Grid.Row="2"
            Padding="24,14"
            BorderBrush="#2A2A2E"
            BorderThickness="0,1,0,0">
            <DockPanel LastChildFill="False">
                <TextBlock
                    VerticalAlignment="Center"
                    DockPanel.Dock="Left"
                    FontSize="11"
                    Foreground="#444"
                    Text="* required" />
                <Button
                    Command="{Binding CancelCommand}"
                    Content="Cancel"
                    DockPanel.Dock="Right"
                    Style="{StaticResource CancelButtonStyle}" />
                <Button
                    Margin="0,0,10,0"
                    Command="{Binding SaveCommand}"
                    Content="{Binding SaveButtonText}"
                    DockPanel.Dock="Right"
                    Style="{StaticResource PrimaryButtonStyle}" />
            </DockPanel>
        </Border>

    </Grid>
</UserControl>