<UserControl x:Class="DevCenter.Views.HomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:DevCenter.Views"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             d:DesignHeight="700"
             d:DesignWidth="1200"
             mc:Ignorable="d">

    <UserControl.Resources>

        <Style x:Key="ScrollBarThumbStyle"
               TargetType="Thumb">
            <Setter Property="Background"
                    Value="#2a2a2a" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="3" />
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver"
                                     Value="True">
                                <Setter Property="Background"
                                        Value="#3a3a3a" />
                            </Trigger>
                            <Trigger Property="IsDragging"
                                     Value="True">
                                <Setter Property="Background"
                                        Value="#4a4a4a" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ScrollBarStyle"
               TargetType="ScrollBar">
            <Setter Property="Width"
                    Value="6" />
            <Setter Property="Background"
                    Value="Transparent" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="Transparent">
                            <Track x:Name="PART_Track"
                                   IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageUpCommand"
                                                  Opacity="0" />
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Margin="1,0"
                                           Style="{StaticResource ScrollBarThumbStyle}" />
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageDownCommand"
                                                  Opacity="0" />
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ScrollViewer">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollViewer">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <ScrollContentPresenter Grid.Row="0"
                                                    Grid.Column="0" />
                            <ScrollBar x:Name="PART_VerticalScrollBar"
                                       Grid.Row="0"
                                       Grid.Column="1"
                                       Maximum="{TemplateBinding ScrollableHeight}"
                                       Style="{StaticResource ScrollBarStyle}"
                                       ViewportSize="{TemplateBinding ViewportHeight}"
                                       Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}"
                                       Value="{TemplateBinding VerticalOffset}" />
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!--  Stat card  -->
        <Style x:Key="StatCardStyle"
               TargetType="Border">
            <Setter Property="Background"
                    Value="#181818" />
            <Setter Property="BorderBrush"
                    Value="#252525" />
            <Setter Property="BorderThickness"
                    Value="0.5" />
            <Setter Property="CornerRadius"
                    Value="10" />
            <Setter Property="Padding"
                    Value="18,16" />
        </Style>

        <!--  Item row card (recent commands / snippets) — now with hover + pressed feedback  -->
        <Style x:Key="ItemCardStyle"
               TargetType="Border">
            <Setter Property="Background"
                    Value="#181818" />
            <Setter Property="BorderBrush"
                    Value="#252525" />
            <Setter Property="BorderThickness"
                    Value="0.5" />
            <Setter Property="CornerRadius"
                    Value="10" />
            <Setter Property="Margin"
                    Value="0,0,0,8" />
            <Setter Property="Cursor"
                    Value="Hand" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver"
                         Value="True">
                    <Setter Property="Background"
                            Value="#1f1f1f" />
                    <Setter Property="BorderBrush"
                            Value="#333" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <!--  Action card (quick links) — now with hover + pressed feedback  -->
        <Style x:Key="ActionCardStyle"
               TargetType="Border">
            <Setter Property="Background"
                    Value="#181818" />
            <Setter Property="BorderBrush"
                    Value="#252525" />
            <Setter Property="BorderThickness"
                    Value="0.5" />
            <Setter Property="CornerRadius"
                    Value="10" />
            <Setter Property="Padding"
                    Value="18,16" />
            <Setter Property="Cursor"
                    Value="Hand" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver"
                         Value="True">
                    <Setter Property="Background"
                            Value="#1f1f1f" />
                    <Setter Property="BorderBrush"
                            Value="#333" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="IconBtnStyle"
               TargetType="Button">
            <Setter Property="Width"
                    Value="28" />
            <Setter Property="Height"
                    Value="28" />
            <Setter Property="BorderThickness"
                    Value="0" />
            <Setter Property="Background"
                    Value="Transparent" />
            <Setter Property="Foreground"
                    Value="#555" />
            <Setter Property="Cursor"
                    Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver"
                                     Value="True">
                                <Setter TargetName="Bg"
                                        Property="Background"
                                        Value="#242424" />
                                <Setter Property="Foreground"
                                        Value="#aaa" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LangBadgeStyle"
               TargetType="Border">
            <Setter Property="Background"
                    Value="#1a2035" />
            <Setter Property="BorderBrush"
                    Value="#2a3a5a" />
            <Setter Property="BorderThickness"
                    Value="0.5" />
            <Setter Property="CornerRadius"
                    Value="4" />
            <Setter Property="Padding"
                    Value="7,3" />
            <Setter Property="HorizontalAlignment"
                    Value="Left" />
            <Setter Property="VerticalAlignment"
                    Value="Center" />
        </Style>

        <!--  "View all" link with hover feedback  -->
        <Style x:Key="ViewAllLinkStyle"
               TargetType="TextBlock">
            <Setter Property="Cursor"
                    Value="Hand" />
            <Setter Property="FontSize"
                    Value="12" />
            <Setter Property="Foreground"
                    Value="#5b9cf6" />
            <Setter Property="Text"
                    Value="View all" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver"
                         Value="True">
                    <Setter Property="Foreground"
                            Value="#7eb0ff" />
                    <Setter Property="TextDecorations"
                            Value="Underline" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <!--  Empty-state card (shared by commands + snippets)  -->
        <Style x:Key="EmptyStateStyle"
               BasedOn="{StaticResource ItemCardStyle}"
               TargetType="Border">
            <Setter Property="Cursor"
                    Value="Arrow" />
            <Setter Property="Padding"
                    Value="20,28" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver"
                         Value="True">
                    <Setter Property="Background"
                            Value="#181818" />
                    <Setter Property="BorderBrush"
                            Value="#252525" />
                </Trigger>
            </Style.Triggers>
        </Style>

    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel HorizontalAlignment="Stretch">


            <!--  Stat cards  -->
            <Grid Margin="0,0,0,28">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Style="{StaticResource StatCardStyle}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <Border Width="32"
                                    Height="32"
                                    Background="#1a2640"
                                    CornerRadius="8">
                                <TextBlock HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           FontFamily="Consolas"
                                           FontSize="12"
                                           Foreground="#5B9CF6"
                                           Text="&gt;_" />
                            </Border>
                            <TextBlock Margin="10,0,0,0"
                                       VerticalAlignment="Center"
                                       FontSize="12"
                                       Foreground="#888"
                                       Text="Commands" />
                        </StackPanel>
                        <TextBlock Margin="0,12,0,0"
                                   FontSize="28"
                                   FontWeight="SemiBold"
                                   Foreground="White"
                                   Text="{Binding CommandCount}" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="2"
                        Style="{StaticResource StatCardStyle}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <Border Width="32"
                                    Height="32"
                                    Background="#1a3a2e"
                                    CornerRadius="8">
                                <TextBlock HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           FontFamily="Consolas"
                                           FontSize="12"
                                           Foreground="#34c48c"
                                           Text="{}{ }" />
                            </Border>
                            <TextBlock Margin="10,0,0,0"
                                       VerticalAlignment="Center"
                                       FontSize="12"
                                       Foreground="#888"
                                       Text="Snippets" />
                        </StackPanel>
                        <TextBlock Margin="0,12,0,0"
                                   FontSize="28"
                                   FontWeight="SemiBold"
                                   Foreground="White"
                                   Text="{Binding SnippetCount}" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="4"
                        Style="{StaticResource StatCardStyle}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <Border Width="32"
                                    Height="32"
                                    Background="#3a2a1a"
                                    CornerRadius="8">
                                <TextBlock HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           FontSize="13"
                                           Foreground="#e0a050"
                                           Text="★" />
                            </Border>
                            <TextBlock Margin="10,0,0,0"
                                       VerticalAlignment="Center"
                                       FontSize="12"
                                       Foreground="#888"
                                       Text="Languages used" />
                        </StackPanel>
                        <TextBlock Margin="0,12,0,0"
                                   FontSize="28"
                                   FontWeight="SemiBold"
                                   Foreground="White"
                                   Text="{Binding LanguageCount}" />
                    </StackPanel>
                </Border>
            </Grid>

            <!--  Quick actions  -->
            <TextBlock Margin="0,0,0,12"
                       FontSize="13"
                       FontWeight="SemiBold"
                       Foreground="White"
                       Text="Quick actions" />
            <StackPanel Orientation="Horizontal"  Margin="0,0,0,28">

                <Border Grid.Column="0"
                        Style="{StaticResource ActionCardStyle}"
                        Margin="0,0,14,0">
                    <Border.InputBindings>
                        <MouseBinding Command="{Binding NewCommandActionCommand}"
                                      MouseAction="LeftClick" />
                    </Border.InputBindings>
                    <DockPanel>
                        <Border Width="36"
                                Height="36"
                                Background="#1a2640"
                                CornerRadius="8"
                                DockPanel.Dock="Left">
                            <TextBlock HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       FontSize="18"
                                       Foreground="#5B9CF6"
                                       Text="+" />
                        </Border>
                        <StackPanel Margin="12,0,0,0"
                                    VerticalAlignment="Center">
                            <TextBlock FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="White"
                                       Text="New command" />
                            <TextBlock Margin="0,2,0,0"
                                       FontSize="11"
                                       Foreground="#666"
                                       Text="Save a script you run often" />
                        </StackPanel>
                    </DockPanel>
                </Border>

                <Border Grid.Column="1"
                        Style="{StaticResource ActionCardStyle}"
                        Margin="0,0,14,0">
                    <Border.InputBindings>
                        <MouseBinding Command="{Binding NewSnippetActionCommand}"
                                      MouseAction="LeftClick" />
                    </Border.InputBindings>
                    <DockPanel>
                        <Border Width="36"
                                Height="36"
                                Background="#1a3a2e"
                                CornerRadius="8"
                                DockPanel.Dock="Left">
                            <TextBlock HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       FontSize="18"
                                       Foreground="#34c48c"
                                       Text="+" />
                        </Border>
                        <StackPanel Margin="12,0,0,0"
                                    VerticalAlignment="Center">
                            <TextBlock FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="White"
                                       Text="New snippet" />
                            <TextBlock Margin="0,2,0,0"
                                       FontSize="11"
                                       Foreground="#666"
                                       Text="Store reusable code with context" />
                        </StackPanel>
                    </DockPanel>
                </Border>
            </StackPanel>

            <!--  Recent commands  -->
            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           VerticalAlignment="Center"
                           FontSize="13"
                           FontWeight="SemiBold"
                           Foreground="White"
                           Text="Recent commands" />
                <TextBlock Grid.Column="1"
                           Style="{StaticResource ViewAllLinkStyle}">
                    <TextBlock.InputBindings>
                        <MouseBinding Command="{Binding GoToCommandsCommand}"
                                      MouseAction="LeftClick" />
                    </TextBlock.InputBindings>
                </TextBlock>
            </Grid>

            <ItemsControl Margin="0,0,0,28"
                          ItemsSource="{Binding RecentCommands}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource ItemCardStyle}">
                            <Border.InputBindings>
                                <MouseBinding Command="{Binding DataContext.OpenCommandCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                              CommandParameter="{Binding}"
                                              MouseAction="LeftClick" />
                            </Border.InputBindings>
                            <Grid Margin="14,11">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <Border Width="30"
                                        Height="30"
                                        Background="#1A2640"
                                        CornerRadius="7">
                                    <TextBlock HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               FontFamily="Consolas"
                                               FontSize="11"
                                               Foreground="#5B9CF6"
                                               Text="&gt;_" />
                                </Border>

                                <StackPanel Grid.Column="1"
                                            Margin="12,0"
                                            VerticalAlignment="Center">
                                    <TextBlock FontSize="13"
                                               FontWeight="SemiBold"
                                               Foreground="White"
                                               Text="{Binding Name}"
                                               TextTrimming="CharacterEllipsis" />
                                    <TextBlock Margin="0,2,0,0"
                                               FontSize="11"
                                               Foreground="#666"
                                               Text="{Binding Description}"
                                               TextTrimming="CharacterEllipsis" />
                                </StackPanel>

                                <TextBlock Grid.Column="2"
                                           VerticalAlignment="Center"
                                           FontSize="11"
                                           Foreground="#444"
                                           Text="{Binding Created, StringFormat='{}{0:MMM dd}'}" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!--  Empty state for recent commands  -->
            <Border Margin="0,0,0,28"
                    Padding="20,28">
                <Border.Style>
                    <Style BasedOn="{StaticResource ItemCardStyle}"
                           TargetType="Border">
                        <Setter Property="Cursor"
                                Value="Arrow" />
                        <Setter Property="Visibility"
                                Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding RecentCommands.Count}"
                                         Value="0">
                                <Setter Property="Visibility"
                                        Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock HorizontalAlignment="Center"
                               FontFamily="Consolas"
                               FontSize="20"
                               Foreground="#3a3a3a"
                               Text="&gt;_" />
                    <TextBlock Margin="0,10,0,0"
                               HorizontalAlignment="Center"
                               FontSize="12"
                               Foreground="#555"
                               Text="No commands yet" />
                    <TextBlock Margin="0,2,0,0"
                               HorizontalAlignment="Center"
                               Cursor="Hand"
                               FontSize="12"
                               Foreground="#5b9cf6"
                               Text="Create your first command">
                        <TextBlock.InputBindings>
                            <MouseBinding Command="{Binding NewCommandActionCommand}"
                                          MouseAction="LeftClick" />
                        </TextBlock.InputBindings>
                    </TextBlock>
                </StackPanel>
            </Border>

            <!--  Recent snippets  -->
            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           VerticalAlignment="Center"
                           FontSize="13"
                           FontWeight="SemiBold"
                           Foreground="White"
                           Text="Recent snippets" />
                <TextBlock Grid.Column="1"
                           Style="{StaticResource ViewAllLinkStyle}">
                    <TextBlock.InputBindings>
                        <MouseBinding Command="{Binding GoToSnippetsCommand}"
                                      MouseAction="LeftClick" />
                    </TextBlock.InputBindings>
                </TextBlock>
            </Grid>

            <ItemsControl ItemsSource="{Binding RecentSnippets}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource ItemCardStyle}">
                            <Border.InputBindings>
                                <MouseBinding Command="{Binding DataContext.OpenSnippetCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                              CommandParameter="{Binding}"
                                              MouseAction="LeftClick" />
                            </Border.InputBindings>
                            <Grid Margin="14,11">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="64" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0"
                                        HorizontalAlignment="Left"
                                        Style="{StaticResource LangBadgeStyle}">
                                    <TextBlock FontFamily="Consolas"
                                               FontSize="10"
                                               Foreground="#5b9cf6"
                                               Text="{Binding Language}" />
                                </Border>

                                <StackPanel Grid.Column="1"
                                            Margin="12,0"
                                            VerticalAlignment="Center">
                                    <TextBlock FontSize="13"
                                               FontWeight="SemiBold"
                                               Foreground="White"
                                               Text="{Binding Title}"
                                               TextTrimming="CharacterEllipsis" />
                                    <TextBlock Margin="0,2,0,0"
                                               FontSize="11"
                                               Foreground="#666"
                                               Text="{Binding Description}"
                                               TextTrimming="CharacterEllipsis" />
                                </StackPanel>

                                <TextBlock Grid.Column="2"
                                           VerticalAlignment="Center"
                                           FontSize="11"
                                           Foreground="#444"
                                           Text="{Binding Created, StringFormat='{}{0:MMM dd}'}" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!--  Empty state for recent snippets  -->
            <Border Padding="20,28">
                <Border.Style>
                    <Style BasedOn="{StaticResource ItemCardStyle}"
                           TargetType="Border">
                        <Setter Property="Cursor"
                                Value="Arrow" />
                        <Setter Property="Visibility"
                                Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding RecentSnippets.Count}"
                                         Value="0">
                                <Setter Property="Visibility"
                                        Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock HorizontalAlignment="Center"
                               FontSize="20"
                               Foreground="#3a3a3a"
                               Text="{}{ }" />
                    <TextBlock Margin="0,10,0,0"
                               HorizontalAlignment="Center"
                               FontSize="12"
                               Foreground="#555"
                               Text="No snippets yet" />
                    <TextBlock Margin="0,2,0,0"
                               HorizontalAlignment="Center"
                               Cursor="Hand"
                               FontSize="12"
                               Foreground="#5b9cf6"
                               Text="Save your first snippet">
                        <TextBlock.InputBindings>
                            <MouseBinding Command="{Binding NewSnippetActionCommand}"
                                          MouseAction="LeftClick" />
                        </TextBlock.InputBindings>
                    </TextBlock>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>