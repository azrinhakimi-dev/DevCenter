<UserControl x:Class="DevCenter.Views.CommandView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:DevCenter.Views"
             mc:Ignorable="d"
             d:DesignHeight="700"
             d:DesignWidth="1200">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>

        <Style x:Key="ScrollBarThumbStyle" TargetType="Thumb">
            <Setter Property="Background" Value="#2a2a2a"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border Background="{TemplateBinding Background}"
                        CornerRadius="3"/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#3a3a3a"/>
                            </Trigger>
                            <Trigger Property="IsDragging" Value="True">
                                <Setter Property="Background" Value="#4a4a4a"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ScrollBarStyle" TargetType="ScrollBar">
            <Setter Property="Width" Value="6"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="Transparent">
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Opacity="0" Command="ScrollBar.PageUpCommand"/>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource ScrollBarThumbStyle}" Margin="1,0"/>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Opacity="0" Command="ScrollBar.PageDownCommand"/>
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ScrollViewer">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollViewer">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <ScrollContentPresenter Grid.Column="0" Grid.Row="0"/>

                            <ScrollBar Grid.Column="1" Grid.Row="0"
                               x:Name="PART_VerticalScrollBar"
                               Style="{StaticResource ScrollBarStyle}"
                               Value="{TemplateBinding VerticalOffset}"
                               Maximum="{TemplateBinding ScrollableHeight}"
                               ViewportSize="{TemplateBinding ViewportHeight}"
                               Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="CmdCardStyle" TargetType="Border">
            <Setter Property="Background" Value="#181818"/>
            <Setter Property="BorderBrush" Value="#252525"/>
            <Setter Property="BorderThickness" Value="0.5"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>

        <Style x:Key="CodeBlockStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="12.5"/>
            <Setter Property="Foreground" Value="#a8b9cc"/>
            <Setter Property="Background" Value="#0d0d0d"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>

        <Style x:Key="RunButtonStyle" TargetType="Button">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0.5"/>
            <Setter Property="BorderBrush" Value="#1a4a2a"/>
            <Setter Property="Background" Value="#0e2018"/>
            <Setter Property="Foreground" Value="#34c48c"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="▶ " FontSize="11" Foreground="#34c48c" VerticalAlignment="Center"/>
                                <ContentPresenter VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#122a1e"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="IconBtnStyle" TargetType="Button">
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#555555"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg" Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#242424"/>
                                <Setter Property="Foreground" Value="#aaaaaa"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- LEFT PANEL -->
        <Grid Grid.Column="0" Margin="0,0,8,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Toolbar -->
            <DockPanel Grid.Row="0" Margin="0,0,0,12" LastChildFill="True">
                <Button Content="+ New"
            DockPanel.Dock="Right"
            Command="{Binding NewCommand}"
            Cursor="Hand"
            Padding="14,7"
            FontSize="13"
            Foreground="White"
            Background="#2563EB"
            BorderThickness="0"
            Margin="10,0,0,0">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                        CornerRadius="6"
                        Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#1D4ED8"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- Search box -->
                <Border Background="#181818"
            BorderBrush="#2A2A2A"
            BorderThickness="1"
            CornerRadius="6">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Search icon -->
                        <TextBlock Grid.Column="0"
                       Text="🔍"
                       FontSize="11"
                       Foreground="#555"
                       VerticalAlignment="Center"
                       Margin="10,0,6,0"/>

                        <!-- Input -->
                        <TextBox Grid.Column="1"
                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                     Background="Transparent"
                     BorderThickness="0"
                     Foreground="#E0E0E0"
                     CaretBrush="#E0E0E0"
                     FontSize="13"
                     Padding="0,8"
                     VerticalAlignment="Center">
                            <TextBox.Style>
                                <Style TargetType="TextBox">
                                    <Style.Triggers>
                                        <Trigger Property="IsFocused" Value="False">
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="TextBox">
                                                        <Grid>
                                                            <ScrollViewer x:Name="PART_ContentHost"
                                                              VerticalAlignment="Center"/>
                                                            <TextBlock Text="Search commands..."
                                                           Foreground="#444"
                                                           FontSize="13"
                                                           VerticalAlignment="Center"
                                                           IsHitTestVisible="False">
                                                                <TextBlock.Style>
                                                                    <Style TargetType="TextBlock">
                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding Text, RelativeSource={RelativeSource AncestorType=TextBox}}" Value="">
                                                                                <Setter Property="Visibility" Value="Visible"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </TextBlock.Style>
                                                            </TextBlock>
                                                        </Grid>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Trigger>
                                        <Trigger Property="IsFocused" Value="True">
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="TextBox">
                                                        <Grid>
                                                            <ScrollViewer x:Name="PART_ContentHost"
                                                              VerticalAlignment="Center"/>
                                                            <TextBlock Text="Search commands..."
                                                           Foreground="#444"
                                                           FontSize="13"
                                                           VerticalAlignment="Center"
                                                           IsHitTestVisible="False">
                                                                <TextBlock.Style>
                                                                    <Style TargetType="TextBlock">
                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding Text, RelativeSource={RelativeSource AncestorType=TextBox}}" Value="">
                                                                                <Setter Property="Visibility" Value="Visible"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </TextBlock.Style>
                                                            </TextBlock>
                                                        </Grid>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBox.Style>
                        </TextBox>

                        <!-- Clear button -->
                        <Button Grid.Column="2"
                    Content="✕"
                    Command="{Binding ClearSearchCommand}"
                    Foreground="#555"
                    Background="Transparent"
                    BorderThickness="0"
                    Cursor="Hand"
                    FontSize="11"
                    Padding="8,0"
                    VerticalAlignment="Center">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SearchText}" Value="">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="Transparent" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Foreground" Value="#aaa"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                    </Grid>
                </Border>
            </DockPanel>

            <!-- Command list -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding Commands}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource CmdCardStyle}">
                                <StackPanel>

                                    <!-- Header -->
                                    <Grid Margin="14,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Icon -->
                                        <Border Width="34" Height="34"
                            Background="#1A2640"
                            CornerRadius="8">
                                            <TextBlock Text=">_"
                                   FontFamily="Consolas"
                                   FontSize="12"
                                   Foreground="#5B9CF6"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                                        </Border>

                                        <!-- Name + Description -->
                                        <StackPanel Grid.Column="1" Margin="12,0" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Name}"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Foreground="White"/>
                                            <TextBlock Text="{Binding Description}"
                                   Foreground="#555"
                                   FontSize="11"
                                   Margin="0,3,0,0"
                                   TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>

                                        <!-- Buttons -->
                                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                            <Button Content="Run"
                                Style="{StaticResource RunButtonStyle}"
                                Margin="0,0,6,0"
                                Command="{Binding DataContext.RunCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                CommandParameter="{Binding}"/>
                                            <Button Style="{StaticResource IconBtnStyle}"
                                Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                CommandParameter="{Binding}">
                                                <TextBlock Text="✖" FontSize="11"/>
                                            </Button>
                                        </StackPanel>
                                    </Grid>

                                    <!-- Toggle script expander -->
                                    <Expander Margin="14,0,14,12"
                          IsExpanded="False">
                                        <Expander.Header>
                                            <TextBlock Text="show script"
                                   FontFamily="Consolas"
                                   FontSize="11"
                                   Foreground="#444"/>
                                        </Expander.Header>
                                        <Expander.Style>
                                            <Style TargetType="Expander">
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="Expander">
                                                            <StackPanel>
                                                                <!-- Toggle button -->
                                                                <ToggleButton x:Name="HeaderSite"
                                                          IsChecked="{Binding IsExpanded, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                                          Background="Transparent"
                                                          BorderThickness="0"
                                                          Cursor="Hand"
                                                          HorizontalAlignment="Left"
                                                          Padding="0">
                                                                    <ToggleButton.Template>
                                                                        <ControlTemplate TargetType="ToggleButton">
                                                                            <StackPanel Orientation="Horizontal">
                                                                                <TextBlock x:Name="Arrow"
                                                                       Text="▶"
                                                                       FontSize="9"
                                                                       Foreground="#444"
                                                                       VerticalAlignment="Center"
                                                                       Margin="0,0,6,0"/>
                                                                                <ContentPresenter/>
                                                                            </StackPanel>
                                                                            <ControlTemplate.Triggers>
                                                                                <Trigger Property="IsChecked" Value="True">
                                                                                    <Setter TargetName="Arrow" Property="Text" Value="▼"/>
                                                                                </Trigger>
                                                                            </ControlTemplate.Triggers>
                                                                        </ControlTemplate>
                                                                    </ToggleButton.Template>
                                                                    <ContentPresenter ContentSource="Header"/>
                                                                </ToggleButton>

                                                                <!-- Collapsible content -->
                                                                <ContentPresenter x:Name="ExpandSite"
                                                              Visibility="Collapsed"
                                                              Margin="0,6,0,0"/>
                                                            </StackPanel>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsExpanded" Value="True">
                                                                    <Setter TargetName="ExpandSite" Property="Visibility" Value="Visible"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </Expander.Style>

                                        <!-- Script content -->
                                        <Border Background="#0d0d0d"
                            BorderBrush="#242424"
                            BorderThickness="1"
                            CornerRadius="6">
                                            <TextBlock Text="{Binding Script}"
                                   Style="{StaticResource CodeBlockStyle}"/>
                                        </Border>
                                    </Expander>

                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>

        <!-- RIGHT PANEL -->
        <Grid Grid.Column="1" Margin="8,0,0,0">
            <Border Background="#181818"
            CornerRadius="10"
            BorderBrush="#2A2A2A"
            BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Topbar — title + running indicator only -->
                    <Border Grid.Row="0"
                    BorderBrush="#2A2A2A"
                    BorderThickness="0,0,0,1"
                    Padding="14,10">
                        <DockPanel LastChildFill="False">

                            <!-- Left: label + active command name -->
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="CLI Output"
                                   Foreground="#888"
                                   FontSize="12"/>
                                <StackPanel Orientation="Horizontal"
                                    Margin="0,3,0,0">
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel">
                                            <Setter Property="Visibility" Value="Visible"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ActiveCommand}" Value="{x:Null}">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>
                                    <TextBlock Text=">_ "
                                       FontFamily="Consolas"
                                       FontSize="12"
                                       Foreground="#5B9CF6"/>
                                    <TextBlock Text="{Binding ActiveCommand.Name}"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="#5B9CF6"/>
                                </StackPanel>
                            </StackPanel>

                            <!-- Right: running indicator + stop -->
                            <StackPanel DockPanel.Dock="Right"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">
                                <TextBlock Text="● Running"
                                   Foreground="#34c48c"
                                   FontSize="12"
                                   VerticalAlignment="Center"
                                   Margin="0,0,12,0"
                                   Visibility="{Binding IsRunning, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                <Button Content="■ Stop"
                                Command="{Binding StopCommand}"
                                Cursor="Hand"
                                FontSize="12"
                                Foreground="#f87171"
                                Background="#2a1010"
                                BorderBrush="#4a1a1a"
                                BorderThickness="0.5"
                                Padding="10,5"
                                Visibility="{Binding IsRunning, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            CornerRadius="6"
                                            Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#3a1515"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </StackPanel>

                        </DockPanel>
                    </Border>

                    <!-- Output body -->
                    <ScrollViewer x:Name="OutputScroller"
                          Grid.Row="1"
                          VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="14,12,8,12">

                            <!-- Script header shown when active -->
                            <StackPanel Margin="0,0,0,10">
                                <StackPanel.Style>
                                    <Style TargetType="StackPanel">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ActiveCommand}" Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </StackPanel.Style>

                                <!-- $ command lines -->
                                <ItemsControl ItemsSource="{Binding ActiveCommandLines}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" Margin="0,1">
                                                <TextBlock Text="$ "
                                                   FontFamily="Consolas"
                                                   FontSize="12.5"
                                                   Foreground="#3a3a3a"/>
                                                <TextBlock Text="{Binding}"
                                                   FontFamily="Consolas"
                                                   FontSize="12.5"
                                                   Foreground="#555"
                                                   TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <!-- Divider -->
                                <Border Height="1"
                                Background="#222"
                                Margin="0,8,0,0"/>
                            </StackPanel>

                            <!-- Output text -->
                            <TextBlock Text="{Binding Output}"
                               FontFamily="Consolas"
                               FontSize="12.5"
                               Foreground="#a8b9cc"
                               TextWrapping="Wrap"/>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- Empty state -->
                    <TextBlock Grid.Row="1"
                       Text="Run a command to see output here."
                       Foreground="#333"
                       FontSize="13"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Output}" Value="">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <!-- Footer -->
                    <Border Grid.Row="2"
                    BorderBrush="#2A2A2A"
                    BorderThickness="0,1,0,0"
                    Padding="14,8">
                        <TextBlock FontFamily="Consolas"
                           FontSize="11"
                           Foreground="#555">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="Idle"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                            <Setter Property="Text" Value="Running..."/>
                                            <Setter Property="Foreground" Value="#34c48c"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Border>

                </Grid>
            </Border>
        </Grid>

    </Grid>
</UserControl>