<UserControl
    x:Class="DevCenter.Views.CommandView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:DevCenter.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="700"
    d:DesignWidth="1200"
    mc:Ignorable="d">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />

        <Style x:Key="ScrollBarThumbStyle" TargetType="Thumb">
            <Setter Property="Background" Value="#2a2a2a" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border Background="{TemplateBinding Background}" CornerRadius="3" />
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#3a3a3a" />
                            </Trigger>
                            <Trigger Property="IsDragging" Value="True">
                                <Setter Property="Background" Value="#4a4a4a" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ScrollBarStyle" TargetType="ScrollBar">
            <Setter Property="Width" Value="6" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="Transparent">
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageUpCommand" Opacity="0" />
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Margin="1,0" Style="{StaticResource ScrollBarThumbStyle}" />
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageDownCommand" Opacity="0" />
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ScrollViewer">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollViewer">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <ScrollContentPresenter Grid.Row="0" Grid.Column="0" />

                            <ScrollBar
                                x:Name="PART_VerticalScrollBar"
                                Grid.Row="0"
                                Grid.Column="1"
                                Maximum="{TemplateBinding ScrollableHeight}"
                                Style="{StaticResource ScrollBarStyle}"
                                ViewportSize="{TemplateBinding ViewportHeight}"
                                Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}"
                                Value="{TemplateBinding VerticalOffset}" />
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="CmdCardStyle" TargetType="Border">
            <Setter Property="Background" Value="#181818" />
            <Setter Property="BorderBrush" Value="#252525" />
            <Setter Property="BorderThickness" Value="0.5" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Margin" Value="0,0,0,10" />
        </Style>

        <Style x:Key="CodeBlockStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Consolas" />
            <Setter Property="FontSize" Value="12.5" />
            <Setter Property="Foreground" Value="#a8b9cc" />
            <Setter Property="Background" Value="#0d0d0d" />
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <!--  Tag chip — clickable, narrows search to that tag  -->
        <Style x:Key="TagChipStyle" TargetType="Border">
            <Setter Property="Background" Value="#1a1a1f" />
            <Setter Property="BorderBrush" Value="#2e2e34" />
            <Setter Property="BorderThickness" Value="0.5" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Padding" Value="7,2" />
            <Setter Property="Margin" Value="0,0,6,0" />
            <Setter Property="Cursor" Value="Hand" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#23232a" />
                    <Setter Property="BorderBrush" Value="#3a3a44" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="RunButtonStyle" TargetType="Button">
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="BorderThickness" Value="0.5" />
            <Setter Property="BorderBrush" Value="#1a4a2a" />
            <Setter Property="Background" Value="#0e2018" />
            <Setter Property="Foreground" Value="#34c48c" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="Medium" />
            <Setter Property="Padding" Value="10,5" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            Padding="{TemplateBinding Padding}"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="6">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock
                                    VerticalAlignment="Center"
                                    FontSize="11"
                                    Foreground="#34c48c"
                                    Text="▶ " />
                                <ContentPresenter VerticalAlignment="Center" />
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#122a1e" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="IconBtnStyle" TargetType="Button">
            <Setter Property="Width" Value="28" />
            <Setter Property="Height" Value="28" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#555555" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            x:Name="Bg"
                            Background="{TemplateBinding Background}"
                            CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#242424" />
                                <Setter Property="Foreground" Value="#aaaaaa" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!--  LEFT PANEL  -->
        <Grid Grid.Column="0" Margin="0,0,8,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!--  Toolbar  -->
            <DockPanel
                Grid.Row="0"
                Margin="0,0,0,12"
                LastChildFill="True">
                <Button
                    Margin="10,0,0,0"
                    Padding="14,7"
                    Background="#2563EB"
                    BorderThickness="0"
                    Command="{Binding NewCommand}"
                    Content="+ New"
                    Cursor="Hand"
                    DockPanel.Dock="Right"
                    FontSize="13"
                    Foreground="White">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border
                                Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#1D4ED8" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!--  Search box  -->
                <Border
                    Background="#181818"
                    BorderBrush="#2A2A2A"
                    BorderThickness="1"
                    CornerRadius="6">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <!--  Search icon  -->
                        <TextBlock
                            Grid.Column="0"
                            Margin="10,0,6,0"
                            VerticalAlignment="Center"
                            FontSize="11"
                            Foreground="#555"
                            Text="🔍" />

                        <!--  Input  -->
                        <TextBox
                            Grid.Column="1"
                            Padding="0,8"
                            VerticalAlignment="Center"
                            Background="Transparent"
                            BorderThickness="0"
                            CaretBrush="#E0E0E0"
                            FontSize="13"
                            Foreground="#E0E0E0"
                            Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}">
                            <TextBox.Style>
                                <Style TargetType="TextBox">
                                    <Style.Triggers>
                                        <Trigger Property="IsFocused" Value="False">
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="TextBox">
                                                        <Grid>
                                                            <ScrollViewer x:Name="PART_ContentHost" VerticalAlignment="Center" />
                                                            <TextBlock
                                                                VerticalAlignment="Center"
                                                                FontSize="13"
                                                                Foreground="#444"
                                                                IsHitTestVisible="False"
                                                                Text="Search by name, tag...">
                                                                <TextBlock.Style>
                                                                    <Style TargetType="TextBlock">
                                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding Text, RelativeSource={RelativeSource AncestorType=TextBox}}" Value="">
                                                                                <Setter Property="Visibility" Value="Visible" />
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </TextBlock.Style>
                                                            </TextBlock>
                                                        </Grid>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Trigger>
                                        <Trigger Property="IsFocused" Value="True">
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="TextBox">
                                                        <Grid>
                                                            <ScrollViewer x:Name="PART_ContentHost" VerticalAlignment="Center" />
                                                            <TextBlock
                                                                VerticalAlignment="Center"
                                                                FontSize="13"
                                                                Foreground="#444"
                                                                IsHitTestVisible="False"
                                                                Text="Search by name, tag...">
                                                                <TextBlock.Style>
                                                                    <Style TargetType="TextBlock">
                                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding Text, RelativeSource={RelativeSource AncestorType=TextBox}}" Value="">
                                                                                <Setter Property="Visibility" Value="Visible" />
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </TextBlock.Style>
                                                            </TextBlock>
                                                        </Grid>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBox.Style>
                        </TextBox>

                        <!--  Clear button  -->
                        <Button
                            Grid.Column="2"
                            Padding="8,0"
                            VerticalAlignment="Center"
                            Background="Transparent"
                            BorderThickness="0"
                            Command="{Binding ClearSearchCommand}"
                            Content="✕"
                            Cursor="Hand"
                            FontSize="11"
                            Foreground="#555">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SearchText}" Value="">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Padding="{TemplateBinding Padding}" Background="Transparent">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Foreground" Value="#aaa" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                    </Grid>
                </Border>
            </DockPanel>

            <!--  Command list  -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding Commands}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource CmdCardStyle}">
                                <StackPanel>

                                    <!--  Header  -->
                                    <Grid Margin="14,12,14,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <!--  Icon  -->
                                        <Border
                                            Width="34"
                                            Height="34"
                                            Background="#1A2640"
                                            CornerRadius="8">
                                            <TextBlock
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                FontFamily="Consolas"
                                                FontSize="12"
                                                Foreground="#5B9CF6"
                                                Text="&gt;_" />
                                        </Border>

                                        <!--  Name + Description  -->
                                        <StackPanel
                                            Grid.Column="1"
                                            Margin="12,0"
                                            VerticalAlignment="Center">
                                            <TextBlock
                                                FontSize="13"
                                                FontWeight="SemiBold"
                                                Foreground="White"
                                                Text="{Binding Name}" />
                                            <TextBlock
                                                Margin="0,3,0,0"
                                                FontSize="11"
                                                Foreground="#555"
                                                Text="{Binding Description}"
                                                TextTrimming="CharacterEllipsis" />
                                        </StackPanel>

                                        <!--  Buttons  -->
                                        <StackPanel
                                            Grid.Column="2"
                                            VerticalAlignment="Center"
                                            Orientation="Horizontal">
                                            <Button
                                                Margin="0,0,6,0"
                                                Command="{Binding DataContext.RunCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"
                                                Content="Run"
                                                Style="{StaticResource RunButtonStyle}" />
                                            <Button
                                                Margin="0,0,6,0"
                                                Command="{Binding DataContext.EditCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"
                                                Style="{StaticResource IconBtnStyle}">
                                                <TextBlock FontSize="11" Text="✎" />
                                            </Button>
                                            <Button
                                                Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"
                                                Style="{StaticResource IconBtnStyle}">
                                                <TextBlock FontSize="11" Text="✖" />
                                            </Button>
                                        </StackPanel>
                                    </Grid>

                                    <!--  Tags row  -->
                                    <ItemsControl Margin="62,8,14,4" ItemsSource="{Binding TagList}">
                                        <ItemsControl.Style>
                                            <Style TargetType="ItemsControl">
                                                <Setter Property="Visibility" Value="Visible" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding TagList.Count}" Value="0">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </ItemsControl.Style>
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel Orientation="Horizontal" />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Style="{StaticResource TagChipStyle}">
                                                    <Border.InputBindings>
                                                        <MouseBinding
                                                            Command="{Binding DataContext.FilterByTagCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="{Binding}"
                                                            MouseAction="LeftClick" />
                                                    </Border.InputBindings>
                                                    <TextBlock
                                                        FontSize="10.5"
                                                        Foreground="#888"
                                                        Text="{Binding}" />
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <!--  Toggle script expander  -->
                                    <Expander Margin="14,4,14,12" IsExpanded="False">
                                        <Expander.Header>
                                            <TextBlock
                                                FontFamily="Consolas"
                                                FontSize="11"
                                                Foreground="#444"
                                                Text="show script" />
                                        </Expander.Header>
                                        <Expander.Style>
                                            <Style TargetType="Expander">
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="Expander">
                                                            <StackPanel>
                                                                <!--  Toggle button  -->
                                                                <ToggleButton
                                                                    x:Name="HeaderSite"
                                                                    Padding="0"
                                                                    HorizontalAlignment="Left"
                                                                    Background="Transparent"
                                                                    BorderThickness="0"
                                                                    Cursor="Hand"
                                                                    IsChecked="{Binding IsExpanded, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                                                    <ToggleButton.Template>
                                                                        <ControlTemplate TargetType="ToggleButton">
                                                                            <StackPanel Orientation="Horizontal">
                                                                                <TextBlock
                                                                                    x:Name="Arrow"
                                                                                    Margin="0,0,6,0"
                                                                                    VerticalAlignment="Center"
                                                                                    FontSize="9"
                                                                                    Foreground="#444"
                                                                                    Text="▶" />
                                                                                <ContentPresenter />
                                                                            </StackPanel>
                                                                            <ControlTemplate.Triggers>
                                                                                <Trigger Property="IsChecked" Value="True">
                                                                                    <Setter TargetName="Arrow" Property="Text" Value="▼" />
                                                                                </Trigger>
                                                                            </ControlTemplate.Triggers>
                                                                        </ControlTemplate>
                                                                    </ToggleButton.Template>
                                                                    <ContentPresenter ContentSource="Header" />
                                                                </ToggleButton>

                                                                <!--  Collapsible content  -->
                                                                <ContentPresenter
                                                                    x:Name="ExpandSite"
                                                                    Margin="0,6,0,0"
                                                                    Visibility="Collapsed" />
                                                            </StackPanel>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsExpanded" Value="True">
                                                                    <Setter TargetName="ExpandSite" Property="Visibility" Value="Visible" />
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </Expander.Style>

                                        <!--  Script content  -->
                                        <Border
                                            Background="#0d0d0d"
                                            BorderBrush="#242424"
                                            BorderThickness="1"
                                            CornerRadius="6">
                                            <TextBlock Style="{StaticResource CodeBlockStyle}" Text="{Binding Script}" />
                                        </Border>
                                    </Expander>

                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>

        <!--  RIGHT PANEL  -->
        <Grid Grid.Column="1" Margin="8,0,0,0">
            <Border
                Background="#181818"
                BorderBrush="#2A2A2A"
                BorderThickness="1"
                CornerRadius="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!--  Topbar — title + running indicator only  -->
                    <Border
                        Grid.Row="0"
                        Padding="14,10"
                        BorderBrush="#2A2A2A"
                        BorderThickness="0,0,0,1">
                        <DockPanel LastChildFill="False">

                            <!--  Left: label + active command name  -->
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock
                                    FontSize="12"
                                    Foreground="#888"
                                    Text="CLI Output" />
                                <StackPanel Margin="0,3,0,0" Orientation="Horizontal">
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel">
                                            <Setter Property="Visibility" Value="Visible" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ActiveCommand}" Value="{x:Null}">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>
                                    <TextBlock
                                        FontFamily="Consolas"
                                        FontSize="12"
                                        Foreground="#5B9CF6"
                                        Text="&gt;_ " />
                                    <TextBlock
                                        FontSize="12"
                                        FontWeight="SemiBold"
                                        Foreground="#5B9CF6"
                                        Text="{Binding ActiveCommand.Name}" />
                                </StackPanel>
                            </StackPanel>

                            <!--  Right: running indicator + stop  -->
                            <StackPanel
                                VerticalAlignment="Center"
                                DockPanel.Dock="Right"
                                Orientation="Horizontal">
                                <TextBlock
                                    Margin="0,0,12,0"
                                    VerticalAlignment="Center"
                                    FontSize="12"
                                    Foreground="#34c48c"
                                    Text="● Running"
                                    Visibility="{Binding IsRunning, Converter={StaticResource BoolToVisibilityConverter}}" />
                                <Button
                                    Padding="10,5"
                                    Background="#2a1010"
                                    BorderBrush="#4a1a1a"
                                    BorderThickness="0.5"
                                    Command="{Binding StopCommand}"
                                    Content="■ Stop"
                                    Cursor="Hand"
                                    FontSize="12"
                                    Foreground="#f87171"
                                    Visibility="{Binding IsRunning, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border
                                                Padding="{TemplateBinding Padding}"
                                                Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="6">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#3a1515" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </StackPanel>

                        </DockPanel>
                    </Border>

                    <!--  Output body  -->
                    <ScrollViewer
                        x:Name="OutputScroller"
                        Grid.Row="1"
                        VerticalScrollBarVisibility="Auto">
                        <ItemsControl Margin="14,12,8,12" ItemsSource="{Binding OutputBlocks}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <ContentControl Content="{Binding}">
                                        <ContentControl.Style>
                                            <Style TargetType="ContentControl">
                                                <Style.Triggers>

                                                    <!--  separator  -->
                                                    <DataTrigger Binding="{Binding Kind}" Value="separator">
                                                        <Setter Property="ContentTemplate">
                                                            <Setter.Value>
                                                                <DataTemplate>
                                                                    <Grid Margin="0,10,0,10">
                                                                        <Grid.ColumnDefinitions>
                                                                            <ColumnDefinition Width="*" />
                                                                        </Grid.ColumnDefinitions>
                                                                        <Border Height="1" Background="#2a2a2a" />
                                                                    </Grid>
                                                                </DataTemplate>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </DataTrigger>

                                                    <!--  cmd  -->
                                                    <DataTrigger Binding="{Binding Kind}" Value="cmd">
                                                        <Setter Property="ContentTemplate">
                                                            <Setter.Value>
                                                                <DataTemplate>
                                                                    <Border
                                                                        Margin="0,2,0,4"
                                                                        Padding="10,6"
                                                                        Background="#0f1a2a"
                                                                        BorderBrush="#1a3a5a"
                                                                        BorderThickness="0,0,0,0"
                                                                        CornerRadius="4">
                                                                        <StackPanel Orientation="Horizontal">
                                                                            <TextBlock
                                                                                FontFamily="Consolas"
                                                                                FontSize="12.5"
                                                                                FontWeight="Bold"
                                                                                Foreground="#3a6ea8"
                                                                                Text="$ " />
                                                                            <TextBlock
                                                                                FontFamily="Consolas"
                                                                                FontSize="12.5"
                                                                                Foreground="#5b9cf6"
                                                                                Text="{Binding Text}"
                                                                                TextWrapping="Wrap" />
                                                                        </StackPanel>
                                                                    </Border>
                                                                </DataTemplate>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </DataTrigger>

                                                    <!--  output  -->
                                                    <DataTrigger Binding="{Binding Kind}" Value="output">
                                                        <Setter Property="ContentTemplate">
                                                            <Setter.Value>
                                                                <DataTemplate>
                                                                    <TextBlock
                                                                        Margin="0,1"
                                                                        FontFamily="Consolas"
                                                                        FontSize="12.5"
                                                                        Foreground="#a8b9cc"
                                                                        Text="{Binding Text}"
                                                                        TextWrapping="Wrap" />
                                                                </DataTemplate>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </DataTrigger>

                                                    <!--  error  -->
                                                    <DataTrigger Binding="{Binding Kind}" Value="error">
                                                        <Setter Property="ContentTemplate">
                                                            <Setter.Value>
                                                                <DataTemplate>
                                                                    <TextBlock
                                                                        Margin="0,1"
                                                                        FontFamily="Consolas"
                                                                        FontSize="12.5"
                                                                        Foreground="#f87171"
                                                                        Text="{Binding Text}"
                                                                        TextWrapping="Wrap" />
                                                                </DataTemplate>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </DataTrigger>

                                                </Style.Triggers>
                                            </Style>
                                        </ContentControl.Style>
                                    </ContentControl>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <!--  Empty state  -->
                    <TextBlock
                        Grid.Row="1"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        FontSize="13"
                        Foreground="#333"
                        Text="Run a command to see output here.">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding OutputBlocks.Count}" Value="0">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <!--  Footer  -->
                    <Border
                        Grid.Row="2"
                        Padding="14,8"
                        BorderBrush="#2A2A2A"
                        BorderThickness="0,1,0,0">
                        <TextBlock
                            FontFamily="Consolas"
                            FontSize="11"
                            Foreground="#555">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="Idle" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                            <Setter Property="Text" Value="Running..." />
                                            <Setter Property="Foreground" Value="#34c48c" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Border>

                </Grid>
            </Border>
        </Grid>

    </Grid>
</UserControl>