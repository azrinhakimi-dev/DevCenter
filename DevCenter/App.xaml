<Application x:Class="DevCenter.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:DevCenter.ViewModel"
             xmlns:views="clr-namespace:DevCenter.Views">
    <Application.Resources>

        <DataTemplate DataType="{x:Type vm:HomeViewModel}">
            <views:HomeView/>
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:SnippetViewModel}">
            <views:SnippetView/>
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:CommandViewModel}">
            <views:CommandView/>
        </DataTemplate>

    </Application.Resources>
</Application>