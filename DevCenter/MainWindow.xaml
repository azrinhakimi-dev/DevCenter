<Window
    x:Class="DevCenter.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:viewmodel="clr-namespace:DevCenter.ViewModel"
    xmlns:views="clr-namespace:DevCenter.Views"
    Title="DevCenter"
    Width="1400"
    Height="850"
    MinWidth="1200"
    MinHeight="750"
    Background="#0f0f0f"
    WindowStartupLocation="CenterScreen">

    <Window.Resources>

        <!--  Nav item style  -->
        <Style x:Key="NavItemStyle" TargetType="RadioButton">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="#999999" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="GroupName" Value="Navigation" />
            <Setter Property="Margin" Value="0,4" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border
                            x:Name="Bg"
                            Padding="10,7"
                            Background="Transparent"
                            CornerRadius="7">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#222222" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#1e2a3a" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!--  Icon text style (simulated via geometry; use text with icon font if available)  -->
        <Style x:Key="NavLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#999999" />
            <Setter Property="FontSize" Value="13.5" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style
            x:Key="NavLabelActiveStyle"
            BasedOn="{StaticResource NavLabelStyle}"
            TargetType="TextBlock">
            <Setter Property="Foreground" Value="#e8e8e8" />
            <Setter Property="FontWeight" Value="Medium" />
        </Style>

        <Style x:Key="SectionLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#555555" />
            <Setter Property="FontSize" Value="10" />
            <Setter Property="FontWeight" Value="Medium" />
            <Setter Property="Margin" Value="8,8,0,4" />
        </Style>

        <Style x:Key="TopbarButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#1e2a45" />
            <Setter Property="BorderBrush" Value="#2f4070" />
            <Setter Property="BorderThickness" Value="0.5" />
            <Setter Property="Foreground" Value="#5b9cf6" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="Medium" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Padding" Value="13,6" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            Padding="{TemplateBinding Padding}"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="7">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#243260" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="MetricCardStyle" TargetType="Border">
            <Setter Property="Background" Value="#181818" />
            <Setter Property="BorderBrush" Value="#252525" />
            <Setter Property="BorderThickness" Value="0.5" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="16" />
        </Style>

        <Style x:Key="MetricValueStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#e8e8e8" />
            <Setter Property="FontSize" Value="22" />
            <Setter Property="FontWeight" Value="Medium" />
            <Setter Property="Margin" Value="0,6,0,0" />
        </Style>

        <Style x:Key="MetricSubStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#555555" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Margin" Value="0,3,0,0" />
        </Style>

    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!--  ═══════════════════════════════════ SIDEBAR ═══════════════════════════════════  -->
        <Grid Grid.Column="0" Background="#161616">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!--  Logo header  -->
            <Border
                Grid.Row="0"
                Padding="16,20,16,12"
                BorderBrush="#2a2a2a"
                BorderThickness="0,0,0,0.5">
                <StackPanel Orientation="Horizontal">
                    <Border
                        Width="26"
                        Height="26"
                        Margin="0,0,8,0"
                        Background="#3b6fd4"
                        CornerRadius="7">
                        <TextBlock
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            FontSize="10"
                            FontWeight="Medium"
                            Foreground="White"
                            Text="&lt;/&gt;" />
                    </Border>
                    <TextBlock
                        VerticalAlignment="Center"
                        FontSize="14"
                        FontWeight="Medium"
                        Foreground="#e8e8e8"
                        Text="DevCenter" />
                </StackPanel>
            </Border>

            <!--  Nav items  -->
            <StackPanel Grid.Row="1" Margin="8,10,8,0">

                <TextBlock Style="{StaticResource SectionLabelStyle}" Text="WORKSPACE" />

                <RadioButton
                    Command="{Binding GoToHomeCommand}"
                    IsChecked="True"
                    Style="{StaticResource NavItemStyle}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock
                            Width="18"
                            VerticalAlignment="Center"
                            FontSize="15"
                            Foreground="#666666"
                            Text="⊞" />
                        <TextBlock
                            Margin="9,0,0,0"
                            VerticalAlignment="Center"
                            FontSize="13.5"
                            FontWeight="Medium"
                            Foreground="#e8e8e8"
                            Text="Home" />
                    </StackPanel>
                </RadioButton>

                <RadioButton Command="{Binding GoToSnippetCommand}" Style="{StaticResource NavItemStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="18" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock
                            Grid.Column="0"
                            VerticalAlignment="Center"
                            FontFamily="Consolas"
                            FontSize="14"
                            Foreground="#666666"
                            Text="{}{}" />
                        <TextBlock
                            Grid.Column="1"
                            Margin="9,0,0,0"
                            Style="{StaticResource NavLabelStyle}"
                            Text="Snippets" />
                        <!--<Border
                            Grid.Column="2"
                            Padding="6,1"
                            Background="#1e2a3a"
                            CornerRadius="10">
                            <TextBlock
                                FontSize="10"
                                FontWeight="Medium"
                                Foreground="#5b9cf6"
                                Text="12" />
                        </Border>-->
                    </Grid>
                </RadioButton>

                <RadioButton Command="{Binding GoToCommandsCommand}" Style="{StaticResource NavItemStyle}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock
                            Width="18"
                            VerticalAlignment="Center"
                            FontSize="13"
                            Foreground="#666666"
                            Text="⚡" />
                        <TextBlock
                            Margin="9,0,0,0"
                            Style="{StaticResource NavLabelStyle}"
                            Text="Commands" />
                    </StackPanel>
                </RadioButton>

                <TextBlock
                    Margin="8,14,0,4"
                    Style="{StaticResource SectionLabelStyle}"
                    Text="TOOLS" />

                <RadioButton Style="{StaticResource NavItemStyle}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock
                            Width="18"
                            VerticalAlignment="Center"
                            FontSize="14"
                            Foreground="#666666"
                            Text="⚙" />
                        <TextBlock
                            Margin="9,0,0,0"
                            Style="{StaticResource NavLabelStyle}"
                            Text="Settings" />
                    </StackPanel>
                </RadioButton>

            </StackPanel>

            <!--  Right border line  -->
            <Border
                Grid.RowSpan="3"
                Width="0.5"
                HorizontalAlignment="Right"
                BorderBrush="#2a2a2a"
                BorderThickness="0,0,0.5,0" />
        </Grid>

        <!--  ═══════════════════════════════════ MAIN ═══════════════════════════════════  -->
        <Grid Grid.Column="1" Background="#111111">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!--  Topbar  -->
            <Border
                Grid.Row="0"
                Padding="24,16"
                BorderBrush="#222222"
                BorderThickness="0,0,0,0.5">
                <StackPanel>

                    <TextBlock
                        VerticalAlignment="Center"
                        FontSize="15"
                        FontWeight="Medium"
                        Foreground="#e8e8e8"
                        Text="{Binding Navigation.CurrentTitle}" />


                    <TextBlock
                        Margin="0,3,0,0"
                        FontSize="12"
                        Foreground="#666"
                        Text="{Binding Navigation.CurrentPageDescription}" />
                </StackPanel>
            </Border>

            <Grid Grid.Row="1">
                <Border Padding="24,16">
                    <ContentControl Content="{Binding Navigation.CurrentViewModel}" />
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>